# Unreal Engine 5 .gitignore

# Generated / build directories (never committed; regenerated by UE)
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
Platforms/*/Build/

# Generated solution / IDE project files
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj/
*.xcworkspace/
.vs/
.vsconfig
.idea/
*.user

# Rider
_ReSharper*/

# Exported builds / packages
/Packaged/
/Exports/
*.zip
*.dmg

# OS cruft
.DS_Store
Thumbs.db

# Secrets / local config
*.env
secrets.ini

# Claude Code session/harness state
.claude/
